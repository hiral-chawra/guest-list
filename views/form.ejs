<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body id="form-body">
    <h1>Invitation form for opening</h1>
    <p>----------*----------*-----------</p>
    <form method="post" action="/All_Guests">
        <button type="button" id="import-contact-btn" class="btn btn-warning mb-3 w-100">
            <i class="bi bi-person-lines-fill"></i> Import from Contacts
        </button>

        <label class="form-label" for="firstName">First Name:</label>
        <input type="text" id="firstName" name="firstName" class="form-control" required>
        <br>
        <label for="lastName">Last Name:</label>
        <input type="text" id="lastName" name="lastName" class="form-control">
        <br>
        <label for="number">Number:</label>
        <input type="tel" id="number" name="number" class="form-control">
        <br>
        <label for="wpNumber">WhatsApp Number:</label>
        <input type="tel" id="wpNumber" name="wpNumber" class="form-control">
        <br>
        <label for="category">Category:</label>
        <input type="text" id="category" name="category" class="form-control">
        <br>
        <label for="address">Address:</label>
        <input type="text" id="address" name="address" class="form-control" required>
        <br>
        <label for="reference">Refrence:</label>
        <input type="text" id="reference" placeholder="Your name" name="reference" class="form-control" required>
        <br>
        <button id="submit-btn" class="btn btn-success" type=" submit">Submit</button>

        <a href="/All_Guests" class="btn btn-secondary">
            Show All Guests
        </a>
    </form>
    <script src="/elements.js"></script>
</body>

</html>